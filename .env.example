# =============================================
# GIO TELEMETRY — Variables de entorno
# Copia este archivo como .env en tu EC2:
#   cp .env.example ~/.env
# Llena los valores y NUNCA subas .env a GitHub
# =============================================

# --- Base de datos compartida (misma para todas) ---
DB_HOST=ENDPOINT_RDS_AQUI
DB_USER=postgres
DB_PASSWORD=CONTRASEÑA_AQUI
DB_NAME=telemetry
DB_PORT=5432
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Identificador de esta instancia ---
EC2_NAME=gio-web-TUNOMBRE

# --- Dominio No-IP de esta instancia ---
DOMAIN=tudominio.hopto.org

# --- HTTPS: true si ya tienes certificado SSL, false si no ---
USE_HTTPS=false

# --- Puertos (no cambiar salvo necesidad) ---
PORT_UDP=5001
PORT_WEB=8080
PORT_HTTPS=443

# --- Ingesta UDP (batch para mejor rendimiento en RDS) ---
UDP_QUEUE_MAX=20000
UDP_BATCH_SIZE=120
UDP_FLUSH_MS=200
UDP_LOG_EVERY=500

# --- Admin: Secreto para acceder a /admin (flush de DB) ---
# Comparte ESTE MISMO valor entre todos los integrantes del equipo
ADMIN_SECRET=

# --- OSRM: URL del servidor de rutas ---
# Por defecto usa la API publica. Si instalas OSRM local, cambia a:
# OSRM_URL=http://<IP-DE-TU-OSRM>:5000
OSRM_URL=https://router.project-osrm.org

# --- Histórico ---
HISTORY_RANGE_MAX=5000
HISTORY_SAMPLE_MINUTES_DEFAULT=3
HISTORY_SAMPLE_MINUTES_MAX=60
HISTORY_OUTLIER_MAX_SPEED_KMH=240
HISTORY_OUTLIER_MIN_JUMP_KM=5
DEVICES_CACHE_TTL=45
