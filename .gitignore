# =============================================
# GIO TELEMETRY — .gitignore
# =============================================

# Variables de entorno — NUNCA subir al repositorio
.env
*.env
.env.local
.env.production
.env.staging

# Certificados SSL — son locales a cada EC2
*.pem
*.key
*.crt
*.p12

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Logs
*.log
nohup.out
server.log

# VS Code
.vscode/
*.code-workspace

# MacOS
.DS_Store

# Windows
Thumbs.db
desktop.ini
